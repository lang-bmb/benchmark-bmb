// Polynomial Evaluation benchmark — Horner's method
// Measures: array access, multiply-add chains, modular arithmetic
// Workload: degree 1000 polynomial, 5000 points, 100 iterations

fn horner_eval(coeffs: i64, degree: i64, x: i64, modulus: i64) -> i64 = {
    let mut result = load_i64(coeffs + degree * 8);
    let mut i = degree - 1;
    while i >= 0 {
        set result = (result * x + load_i64(coeffs + i * 8)) % modulus;
        set i = i - 1
    };
    result
};

fn main() -> () = {
    let degree = 1000;
    let n_coeffs = degree + 1;
    let n_points = 5000;
    let iters = 100;
    let modulus = 1000000007;

    let coeffs = malloc(n_coeffs * 8);

    // Generate coefficients using LCG
    let mut seed = 42;
    let mut i = 0;
    while i < n_coeffs {
        set seed = (seed * 1103515245 + 12345) band 2147483647;
        let _s = store_i64(coeffs + i * 8, seed % 1000);
        set i = i + 1
    };

    let mut checksum = 0;
    let mut iter = 0;
    while iter < iters {
        let mut x = 1;
        while x <= n_points {
            set checksum = checksum + horner_eval(coeffs, degree, x, modulus);
            set x = x + 1
        };
        set iter = iter + 1
    };

    let _f = free(coeffs);
    print(checksum % modulus)
};
